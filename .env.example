# LiteMindUI Configuration

# API URLs
OLLAMA_API_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=gemma3:1b
FASTAPI_URL=http://localhost:8000

# LiteLLM direct-SDK provider configuration
# No LiteLLM proxy/gateway is required.
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
DEFAULT_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1
DEFAULT_NVIDIA_NIM_MODEL=meta/llama3-70b-instruct

# Optional conversation summary backend override
SUMMARY_BACKEND=ollama
SUMMARY_MODEL=gemma3:1b
SUMMARY_API_BASE=
SUMMARY_API_KEY=

# Database
CHROMA_DB_PATH=/app/chroma_db
SQLALCHEMY_DATABASE_URI=sqlite+aiosqlite:///app/litemindui.db

# File paths
UPLOAD_FOLDER=/app/uploads
STORAGE_PATH=/app/storage

# Security
SECRET_KEY=your-secret-key-change-this-in-production

# Performance tuning
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
NUMEXPR_NUM_THREADS=4

# Web Search Configuration
# Get your API key from https://serpapi.com/
SERP_API_KEY=your-serpapi-key-here
# Optional: Maximum number of search results to retrieve (default: 10)
WEB_SEARCH_MAX_RESULTS=10
# Optional: Timeout for web search requests in seconds (default: 30)
WEB_SEARCH_TIMEOUT=30

# Cache directories (automatically configured by docker-compose)
# HUGGINGFACE_CACHE_DIR=${HOME}/.cache/huggingface
# OLLAMA_CACHE_DIR=${HOME}/.ollama

# Development settings
DEBUG=0
RELOAD=0

# Logging
LOG_LEVEL=INFO