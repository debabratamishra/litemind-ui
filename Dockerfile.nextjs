# ── Stage 1: Dependencies ─────────────────────────────────────────────────────
FROM node:22-alpine AS deps

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files for caching
COPY nextjs-frontend/package.json nextjs-frontend/package-lock.json* ./

# Install all dependencies (do NOT use --omit=dev here).
# The lockfile marks the platform-specific native binary for lightningcss
# (lightningcss-linux-*-musl) as "dev": true because it was generated on macOS
# where it is only reachable through the dev-only Tailwind chain. With
# --omit=dev npm would skip that optional native module, and Tailwind v4's CSS
# build would fail with "Cannot find module 'lightningcss.linux-arm64-musl.node'".
# Keeping dev deps here only inflates the throwaway build layer — the runner
# stage copies only .next/standalone, which bundles just the runtime deps.
RUN npm ci

# ── Stage 2: Builder ──────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Copy node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy all source
COPY nextjs-frontend/ .

# Build-time env — the API URL is rewritten at runtime via the entrypoint,
# but Next.js needs a value present at build time for NEXT_PUBLIC_ vars.
# We use a placeholder that gets substituted in the entrypoint script.
ENV NEXT_PUBLIC_API_URL=http://backend:8000
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# ── Stage 3: Runner ───────────────────────────────────────────────────────────
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Copy only what the production server needs
COPY --from=builder /app/public ./public

# Next.js standalone output (enabled via next.config.ts output: 'standalone')
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD wget -qO- http://localhost:3000/ || exit 1

CMD ["node", "server.js"]
